# 6) Production Setup — Step by Step

---

# connection.py

```python
import pika

def get_connection():
    params = pika.ConnectionParameters(
        host="localhost",
        heartbeat=60,
        blocked_connection_timeout=30
    )
    return pika.BlockingConnection(params)
```

---

Reliable connection settings.

---

---

# exchanges.py

```python
USER_EXCHANGE = "user.events"
BILLING_EXCHANGE = "billing.commands"

TOPIC = "topic"
DIRECT = "direct"
```

---

Centralized exchange definitions.

---

---

# topology.py

```python
from messaging.connection import get_connection
from messaging.exchanges import *

def setup_topology():
    conn = get_connection()
    ch = conn.channel()

    ch.exchange_declare(exchange=USER_EXCHANGE, exchange_type=TOPIC, durable=True)
    ch.exchange_declare(exchange=BILLING_EXCHANGE, exchange_type=DIRECT, durable=True)

    ch.queue_declare(queue="email_queue", durable=True)
    ch.queue_declare(queue="audit_queue", durable=True)

    ch.queue_bind(exchange=USER_EXCHANGE, queue="email_queue", routing_key="user.created")
    ch.queue_bind(exchange=USER_EXCHANGE, queue="audit_queue", routing_key="user.*")

    conn.close()
```

---

This defines broker topology.

